{
  "name": "stock-app",
  "version": "1.0.0",
  "description": "Gestión de stock de indumentaria",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node index.js",
    "client": "cd client && npm run dev",
    "install:all": "npm install && cd client && npm install",
    "seed": "node seed.js",
    "start": "node index.js",
    "build": "cd client && npm run build"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.15.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
